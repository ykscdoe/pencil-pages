{
	"name": "pencildev",
	"displayName": "Pencil",
	"description": "A VS Code extension for Pencil design files",
	"version": "0.6.60",
	"publisher": "highagency",
	"author": "High Agency",
	"license": "SEE LICENSE IN LICENSE",
	"homepage": "https://pencil.dev",
	"categories": [
		"Visualization",
		"Other"
	],
	"keywords": [
		"pencil",
		"design",
		"preview"
	],
	"engines": {
		"vscode": "^1.100.0"
	},
	"main": "./out/main.js",
	"activationEvents": [
		"onStartupFinished"
	],
	"scripts": {
		"dev": "vite build --watch",
		"build:mcp": "cd ../../servers/mcp && ./build-mcp-cross-platform.sh",
		"build:dev": "npm run build:mcp && rm -rf out && cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build && rm -f out/mcp-server-* && cp ../../servers/mcp/mcp-server-* out/ && cp -r assets out && mkdir -p out/data && cp ../../lib/editor/data/*.pen ../../lib/pencil-editor/data/*.lib.pen out/data/",
		"build": "rm -rf out && cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build && rm -f out/mcp-server-* && cp ../../servers/mcp/mcp-server-* out/ && cp -r assets out && mkdir -p out/data && cp ../../lib/editor/data/*.pen ../../lib/pencil-editor/data/*.lib.pen out/data/",
		"package": "vsce package --follow-symlinks --dependencies",
		"package:prerelease": "vsce package --follow-symlinks --dependencies --pre-release",
		"publish:vscode": "vsce publish",
		"publish:vscode:prerelease": "vsce publish --pre-release",
		"publish:ovsx": "ovsx publish",
		"publish:ovsx:prerelease": "ovsx publish --pre-release",
		"sentry:sourcemaps": "sentry-cli sourcemaps inject --org high-agency --project vscode-extension ${SENTRY_AUTH_TOKEN:+--auth-token \"$SENTRY_AUTH_TOKEN\"} ./out && sentry-cli sourcemaps upload --org high-agency --project vscode-extension ${SENTRY_AUTH_TOKEN:+--auth-token \"$SENTRY_AUTH_TOKEN\"} ./out",
		"lint": "biome check"
	},
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "pencil",
					"title": "Pencil",
					"icon": "./assets/icons/pencil-dark.png"
				}
			]
		},
		"views": {
			"pencil": [
				{
					"id": "pencil.sidebar",
					"name": "Pencil Recent Files"
				}
			]
		},
		"icons": {
			"pencil-new": {
				"description": "Pencil New",
				"default": {
					"fontPath": "./out/assets/font/pencil.woff",
					"fontCharacter": "\\E800"
				}
			},
			"pencil-logo": {
				"description": "Pencil Logo",
				"default": {
					"fontPath": "./out/assets/font/pencil.woff",
					"fontCharacter": "\\E801"
				}
			}
		},
		"commands": [
			{
				"command": "pencil.newFile",
				"title": "Pencil: New File",
				"icon": "$(pencil-new)"
			},
			{
				"command": "pencil.toggleDesignMode",
				"title": "Pencil: Toggle Design Mode",
				"icon": "$(screen-full)"
			},
			{
				"command": "pencil.openRawDesignFile",
				"title": "Pencil: Open Design File as Text"
			},
			{
				"command": "pencil.openWelcomeDocument",
				"title": "Pencil: Open Welcome File"
			},
			{
				"command": "pencil.openShadcnDocument",
				"title": "Pencil: Open Shadcn UI File"
			},
			{
				"command": "pencil.openHaloDocument",
				"title": "Pencil: Open Halo File"
			},
			{
				"command": "pencil.openLunarisDocument",
				"title": "Pencil: Open Lunaris File"
			},
			{
				"command": "pencil.openNitroDocument",
				"title": "Pencil: Open Nitro File"
			},
			{
				"command": "pencil.openDemoDocument",
				"title": "Pencil: Open Demo File"
			},
			{
				"command": "pencil.clearRecentFiles",
				"title": "Clear Recent Files",
				"icon": "$(clear-all)"
			},
			{
				"command": "pencil.showSettings",
				"title": "Pencil: Settings"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "pencil.clearRecentFiles",
					"when": "view == pencil.sidebar",
					"group": "navigation"
				}
			],
			"explorer/context": [
				{
					"command": "pencil.openRawDesignFile",
					"when": "resourceExtname == '.pen'",
					"group": "navigation"
				}
			],
			"editor/title": [
				{
					"submenu": "pencil.submenu",
					"group": "navigation"
				}
			],
			"pencil.submenu": [
				{
					"command": "pencil.newFile"
				},
				{
					"command": "pencil.openWelcomeDocument"
				},
				{
					"command": "pencil.openShadcnDocument"
				},
				{
					"command": "pencil.openHaloDocument"
				},
				{
					"command": "pencil.openLunarisDocument"
				},
				{
					"command": "pencil.openNitroDocument"
				},
				{
					"command": "pencil.openDemoDocument"
				}
			]
		},
		"submenus": [
			{
				"id": "pencil.submenu",
				"label": "Pencil",
				"icon": "$(pencil-logo)"
			}
		],
		"keybindings": [
			{
				"command": "pencil.toggleDesignMode",
				"key": "ctrl+shift+\\",
				"mac": "cmd+shift+\\"
			}
		],
		"customEditors": [
			{
				"viewType": "pencil.designEditor",
				"displayName": "Pencil Design Editor",
				"selector": [
					{
						"filenamePattern": "*.pen"
					}
				]
			}
		],
		"languages": [
			{
				"id": "pencil",
				"extensions": [
					".pen"
				],
				"aliases": [
					"Pencil"
				],
				"icon": {
					"light": "./assets/icons/pencil-light.png",
					"dark": "./assets/icons/pencil-dark.png"
				}
			}
		]
	},
	"icon": "./assets/icons/pencil-logo.png",
	"galleryBanner": {
		"color": "#FFFFFF",
		"theme": "light"
	},
	"preview": false,
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.3.197",
		"@aws-sdk/client-s3": "^3.940.0",
		"@ha/agent": "file:../../lib/agent",
		"@ha/ipc": "file:../../lib/ipc",
		"@ha/mcp": "file:../../lib/mcp",
		"@ha/pencil-editor": "file:../../lib/pencil-editor",
		"@ha/schema": "file:../../lib/schema",
		"@ha/shared": "file:../../lib/shared",
		"@sentry/cli": "^2.57.0",
		"@sentry/node": "^10.27.0",
		"@sentry/vite-plugin": "^4.6.1",
		"dotenv": "^17.2.2",
		"eventemitter3": "^5.0.1",
		"js-yaml": "^4.1.0",
		"semver": "^7.7.3",
		"unzipper": "^0.12.3",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^24.1.0",
		"@types/node-ipc": "^9.2.3",
		"@types/semver": "^7.7.1",
		"@types/unzipper": "^0.10.11",
		"@types/vscode": "^1.80.0",
		"@types/ws": "^8.18.1",
		"@vscode/vsce": "^3.6.0",
		"cross-env": "^10.1.0",
		"glob": "^13.0.0",
		"ovsx": "^0.10.6",
		"rollup-plugin-node-externals": "^8.1.2",
		"typescript": "^5.0.0",
		"vite": "^6.0.7"
	},
	"__metadata": {
		"installedTimestamp": 1783524913115,
		"targetPlatform": "undefined",
		"size": 683340417
	}
}